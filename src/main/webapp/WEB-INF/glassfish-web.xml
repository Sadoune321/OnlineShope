<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE glassfish-web-app PUBLIC
    "-//GlassFish.org//DTD GlassFish Application Server 3.1 Servlet 3.0//EN"
    "http://glassfish.org/dtds/glassfish-web-app_3_0-1.dtd">

<glassfish-web-app error-url="">
    <!--
        IMPORTANT : ce context-root DOIT correspondre au nom du WAR déployé.
        Si votre WAR s'appelle SuperretOnline-1.0-SNAPSHOT.war, GlassFish
        utilise ce fichier pour forcer le context-root à /SuperretOnline.
        URL finale : http://localhost:8080/SuperretOnline/shop
    -->
    <context-root>/SuperretOnline</context-root>

    <class-loader delegate="true"/>

    <jsp-config>
        <property name="keepgenerated" value="true"/>
    </jsp-config>
</glassfish-web-app>